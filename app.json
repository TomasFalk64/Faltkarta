{
  "expo": {
    "name": "Fältkarta",
    "slug": "faltkarta",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Faltkarta behover GPS for att visa din position pa kartan.",
        "NSPhotoLibraryUsageDescription": "Faltkarta behover atkomst till bilder for att lagga till foton till observationer.",
        "NSPhotoLibraryAddUsageDescription": "Faltkarta behover spara kopior av observationsbilder i ditt galleri."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.tf64.faltkarta",
      "softwareKeyboardLayoutMode": "adjustPan"    
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-document-picker",
      "expo-location",
      "expo-media-library"
    ],
    "extra": {
      "eas": {
        "projectId": "e8af7241-bb69-4e74-a9ea-f3ae59e2e168"
      }
    }
  }
}
